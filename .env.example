# ─── Airtable ───────────────────────────────────────────────────────────────
# Found at airtable.com → Account → API → Personal Access Tokens
AIRTABLE_API_KEY=your_airtable_personal_access_token

# Found in your Airtable base URL: airtable.com/appXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXX

# The exact name of your table inside the base (case-sensitive)
AIRTABLE_TABLE_NAME=ACC TL

# ─── Clerk (Authentication) ──────────────────────────────────────────────────
# Found at dashboard.clerk.com → Your App → API Keys

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here

# Clerk redirect URLs — keep these as-is for local dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Anthropic (AI Chatbot) ──────────────────────────────────────────────────
# Found at console.anthropic.com → API Keys
 ANTHROPIC_API_KEY=sk-ant-your-key-here
# ─── Logo.dev (Company Logos) ─────────────────────────────────────────────────
# Found at logo.dev → Dashboard → API Keys
NEXT_PUBLIC_LOGO_DEV_TOKEN=pk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
